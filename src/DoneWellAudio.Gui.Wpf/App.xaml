<Application x:Class="DoneWellAudio.Gui.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Color Palette: Dark Fire -->
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="AppPanelBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="AppBorderBrush" Color="#FF3E3E3E"/>
        <SolidColorBrush x:Key="AppForegroundBrush" Color="#FFF0F0F0"/>
        <SolidColorBrush x:Key="AppAccentBrush" Color="#FFFFAA00"/> <!-- Orange -->
        <SolidColorBrush x:Key="AppAccentHighlightBrush" Color="#FFFFCC00"/> <!-- Brighter Orange -->
        <SolidColorBrush x:Key="AppUrgentBrush" Color="#FFFF5555"/> <!-- Red -->
        <SolidColorBrush x:Key="AppWarningBrush" Color="#FFFFAA00"/> <!-- Orange -->
        <SolidColorBrush x:Key="AppSafeBrush" Color="#FFFFFF55"/> <!-- Yellow -->

        <!-- Base Font Size -->
        <sys:Double x:Key="BaseFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">18</sys:Double>

        <!-- Default Control Styles -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AppBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AppAccentBrush}"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}"/>
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- List View Styling -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{StaticResource AppPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}"/>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource AppBorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}"/>
        </Style>

        <!-- GroupBox Styling -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

    </Application.Resources>
</Application>
