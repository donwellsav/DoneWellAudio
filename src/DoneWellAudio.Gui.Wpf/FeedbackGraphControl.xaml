<UserControl x:Class="DoneWellAudio.Gui.Wpf.FeedbackGraphControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DoneWellAudio.Gui.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="400">
    <Grid Background="Black">
        <!-- Waterfall Image -->
        <Image x:Name="WaterfallImage" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor" Visibility="Collapsed"/>

        <!-- Canvas for Spectrum and Confidence -->
        <Canvas x:Name="MainCanvas" ClipToBounds="True"/>

        <!-- Grid Lines / Axes could go here -->
        <TextBlock x:Name="ModeText" Text="Mode" Foreground="Gray" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="5" FontSize="10" Opacity="0.5"/>
    </Grid>
</UserControl>
