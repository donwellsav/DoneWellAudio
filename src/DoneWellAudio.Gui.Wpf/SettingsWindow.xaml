<Window x:Class="DoneWellAudio.Gui.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="550" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- GENERAL TAB -->
            <TabItem Header="General">
                <StackPanel Margin="10">
                    <TextBlock Text="Detector Settings" FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Sensitivity:" Width="140" VerticalAlignment="Center"/>
                        <ComboBox x:Name="SensitivityCombo" Width="150" SelectionChanged="SensitivityCombo_SelectionChanged" AutomationProperties.Name="Sensitivity"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Response Speed:" Width="140" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ResponseCombo" Width="150" SelectionChanged="ResponseCombo_SelectionChanged" AutomationProperties.Name="Response Speed"/>
                    </StackPanel>

                    <TextBlock Text="Analysis" FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Bell Bands:" Width="140" VerticalAlignment="Center"/>
                        <ComboBox x:Name="BellBandsCombo" Width="150" SelectionChanged="BellBandsCombo_SelectionChanged" AutomationProperties.Name="Number of bell bands"/>
                    </StackPanel>

                    <CheckBox x:Name="HarmonicFilterCheck" Content="Filter Harmonics (Music Rejection)" Margin="0,0,0,10" Checked="HarmonicFilterCheck_Changed" Unchecked="HarmonicFilterCheck_Changed"/>

                    <TextBlock Text="Room Prediction" FontWeight="Bold" Margin="0,15,0,10"/>
                    <CheckBox x:Name="RoomPriorCheck" Content="Bias Detection with Room Acoustics" Margin="0,0,0,10" Checked="RoomPriorCheck_Changed" Unchecked="RoomPriorCheck_Changed"/>
                    <CheckBox x:Name="ImperialCheck" Content="Use Imperial Units (ft/in)" Margin="0,0,0,20" Checked="ImperialCheck_Changed" Unchecked="ImperialCheck_Changed"/>
                </StackPanel>
            </TabItem>

            <!-- ADVANCED TAB -->
            <TabItem Header="Advanced">
                <StackPanel Margin="10">
                    <TextBlock Text="Expert Tuning" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource AppUrgentBrush}"/>

                    <CheckBox x:Name="SpectralWhiteningCheck" Content="Enable Spectral Whitening (Pink Noise Comp.)" Margin="0,0,0,15" Checked="Advanced_Changed" Unchecked="Advanced_Changed" ToolTip="Flattens the spectrum before peak detection. Recommended: On."/>

                    <TextBlock Text="Freeze Confidence Threshold:" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="FreezeThresholdSlider" Minimum="0.5" Maximum="1.0" Value="0.72" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="Advanced_Changed"/>
                        <TextBlock Text="{Binding ElementName=FreezeThresholdSlider, Path=Value, StringFormat=F2}" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Max Frequency Drift (Hz):" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="DriftSlider" Minimum="1.0" Maximum="20.0" Value="8.0" TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="Advanced_Changed"/>
                        <TextBlock Text="{Binding ElementName=DriftSlider, Path=Value, StringFormat=F1}" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Custom Sensitivity Panel -->
                    <StackPanel x:Name="CustomSensitivityPanel" Visibility="Collapsed" Background="#11FFFFFF" Margin="-5,5,-5,5" Padding="10">
                        <TextBlock Text="Custom Base Threshold (Prominence dB):" Margin="5,5,0,5" FontWeight="SemiBold"/>
                        <Grid Margin="5,0,5,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="ProminenceSlider" Minimum="1.0" Maximum="20.0" Value="6.0" TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="Advanced_Changed"/>
                            <TextBlock Text="{Binding ElementName=ProminenceSlider, Path=Value, StringFormat=F1}" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Active only when Sensitivity is 'Custom'" FontStyle="Italic" FontSize="10" Foreground="Gray" Margin="5,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="ResetButton" Content="Reset Defaults" Width="100" Click="Reset_Click"/>
            <Button x:Name="CloseButton" Content="Close" Width="80" Margin="10,0,0,0" Background="{StaticResource AppAccentBrush}" Foreground="Black" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
