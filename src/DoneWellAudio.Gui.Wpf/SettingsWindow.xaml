<Window x:Class="DoneWellAudio.Gui.Wpf.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="350" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">
    <StackPanel Margin="20">
        <TextBlock Text="Interface Settings" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Text="Font Size:" Margin="0,0,0,5"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <Slider x:Name="FontSizeSlider" Minimum="12" Maximum="32" Width="240"
                    TickPlacement="BottomRight" TickFrequency="2" IsSnapToTickEnabled="True"
                    ValueChanged="FontSizeSlider_ValueChanged"/>
            <TextBlock x:Name="FontSizeValueText" Text="18" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>

        <TextBlock Text="Preview:" Margin="0,0,0,5"/>
        <Border BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,20" Background="{StaticResource AppPanelBrush}">
            <TextBlock x:Name="PreviewText" Text="The quick brown fox jumps over the lazy dog."/>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="ResetButton" Content="Reset" Width="80" Click="Reset_Click"/>
            <Button x:Name="CloseButton" Content="Close" Width="80" Margin="10,0,0,0" Background="{StaticResource AppAccentBrush}" Foreground="Black" Click="Close_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
