<Window x:Class="DoneWellAudio.Gui.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DoneWellAudio" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top controls -->
        <Border Grid.Row="0" Padding="12" CornerRadius="8" Background="#FF0F172A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Input device:" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <ComboBox x:Name="DeviceCombo" Width="520" Margin="0,0,16,0" AutomationProperties.Name="Input device"/>
                    <TextBlock Text="Bell bands:" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <ComboBox x:Name="BellBandsCombo" Width="80" AutomationProperties.Name="Number of bell bands"/>
                    <CheckBox x:Name="HarmonicFilterCheck" Content="Filter Harmonics" Foreground="White" IsChecked="True" VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="StartButton" Content="Start" Margin="10,0" Padding="14,8" Click="Start_Click" ToolTip="Start capturing audio"/>
                <Button Grid.Column="2" x:Name="FreezeButton" Content="Freeze" Margin="10,0" Padding="14,8" Click="Freeze_Click" ToolTip="Freeze the current analysis results"/>
                <Button Grid.Column="3" x:Name="RescanButton" Content="Rescan" Margin="10,0" Padding="14,8" Click="Rescan_Click" ToolTip="Reset the analysis and start fresh"/>
                <Button Grid.Column="4" x:Name="StopButton" Content="Stop" Margin="10,0" Padding="14,8" Click="Stop_Click" ToolTip="Stop capturing audio"/>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Feedback candidates (live analysis)" Grid.Column="0" Padding="8" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock x:Name="StatusText" DockPanel.Dock="Top" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <ListView x:Name="CandidatesList">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Freq (Hz)" DisplayMemberBinding="{Binding FrequencyHz}" Width="90"/>
                                <GridViewColumn Header="Conf" DisplayMemberBinding="{Binding Confidence}" Width="70"/>
                                <GridViewColumn Header="Q~" DisplayMemberBinding="{Binding EstimatedQ}" Width="70"/>
                                <GridViewColumn Header="Prom (dB)" DisplayMemberBinding="{Binding ProminenceDb}" Width="85"/>
                                <GridViewColumn Header="Persist" DisplayMemberBinding="{Binding TotalHits}" Width="70"/>
                                <GridViewColumn Header="Stable (Hzσ)" DisplayMemberBinding="{Binding FrequencyStdDevHz}" Width="95"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </GroupBox>

            <GroupBox Header="EQ suggestions (analog EQ)" Grid.Column="1" Padding="8">
                <DockPanel>
                    <TextBlock Text="Format: Band 1: 630 Hz, cut -6 dB, Q 8.0" DockPanel.Dock="Top" Margin="0,0,0,6" Foreground="#FF334155"/>
                    <ListView x:Name="RecsList">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Band" DisplayMemberBinding="{Binding BandIndex}" Width="50"/>
                                <GridViewColumn Header="Freq (Hz)" DisplayMemberBinding="{Binding FrequencyHz}" Width="90"/>
                                <GridViewColumn Header="Gain (dB)" DisplayMemberBinding="{Binding GainDb}" Width="90"/>
                                <GridViewColumn Header="Q" DisplayMemberBinding="{Binding Q}" Width="60"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </GroupBox>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="2" Text="Tip: Keep levels low while testing feedback detection." Foreground="#FF64748B"/>
    </Grid>
</Window>
