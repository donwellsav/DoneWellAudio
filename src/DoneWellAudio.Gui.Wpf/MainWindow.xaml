<Window x:Class="DoneWellAudio.Gui.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DoneWellAudio - Feedback Detector" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">

    <Window.Resources>
        <!-- Icons -->
        <Geometry x:Key="IconPlay">M8,5.14V19.14L19,12.14L8,5.14Z</Geometry>
        <Geometry x:Key="IconStop">M6,6H18V18H6V6Z</Geometry>
        <Geometry x:Key="IconPause">M14,19H18V5H14M6,19H10V5H6V19Z</Geometry>
        <Geometry x:Key="IconRefresh">M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z</Geometry>
        <Geometry x:Key="IconSettings">M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.95C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z</Geometry>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Controls -->
            <RowDefinition Height="3*"/>   <!-- Candidates -->
            <RowDefinition Height="Auto"/> <!-- Splitter -->
            <RowDefinition Height="1*"/>   <!-- EQ Recommendations -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Top Control Bar -->
        <Border Grid.Row="0" Padding="10" CornerRadius="8" Background="{StaticResource AppPanelBrush}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Inputs -->
                    <ColumnDefinition Width="*"/>    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- Buttons -->
                    <ColumnDefinition Width="Auto"/> <!-- Settings -->
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Input:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="DeviceCombo" Width="350" AutomationProperties.Name="Input device"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                         <TextBlock Text="Level:" VerticalAlignment="Center" Margin="0,0,10,0" Width="40"/>
                         <ProgressBar x:Name="InputLevelMeter" Width="300" Height="8" Maximum="1.0" Value="0.0" Foreground="{StaticResource AppAccentHighlightBrush}" Background="{StaticResource AppBorderBrush}" BorderThickness="0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                         <TextBlock Text="Bands:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                         <ComboBox x:Name="BellBandsCombo" Width="80" AutomationProperties.Name="Number of bell bands"/>
                         <CheckBox x:Name="HarmonicFilterCheck" Content="Filter Harmonics" IsChecked="True" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="StartButton" Style="{StaticResource IconButton}" Click="Start_Click" ToolTip="Start Scanning">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPlay}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="START"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="FreezeButton" Style="{StaticResource IconButton}" Click="Freeze_Click" ToolTip="Freeze Analysis">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPause}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="FREEZE"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="RescanButton" Style="{StaticResource IconButton}" Click="Rescan_Click" ToolTip="Reset &amp; Rescan">
                         <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconRefresh}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="RESCAN"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="StopButton" Style="{StaticResource IconButton}" Click="Stop_Click" ToolTip="Stop Capture">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconStop}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="STOP"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button Grid.Column="3" x:Name="SettingsButton" Click="Settings_Click" Margin="20,0,0,0" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" ToolTip="Settings">
                    <Path Data="{StaticResource IconSettings}" Fill="{StaticResource AppForegroundBrush}" Width="20" Height="20" Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>

        <!-- Feedback Candidates List -->
        <GroupBox Grid.Row="1" Header="Live Feedback Candidates" Margin="0,0,0,10">
            <ListView x:Name="CandidatesList" BorderThickness="0" Background="Transparent">
                <ListView.ItemContainerStyle>
                     <Style TargetType="ListViewItem">
                        <Setter Property="Foreground" Value="{Binding RowColor}"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="5"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Freq (Hz)" DisplayMemberBinding="{Binding FrequencyHz}" Width="120"/>
                        <GridViewColumn Header="Conf" DisplayMemberBinding="{Binding Confidence}" Width="100"/>
                        <GridViewColumn Header="Q~" DisplayMemberBinding="{Binding EstimatedQ}" Width="100"/>
                        <GridViewColumn Header="Prom (dB)" DisplayMemberBinding="{Binding ProminenceDb}" Width="120"/>
                        <GridViewColumn Header="Persist" DisplayMemberBinding="{Binding TotalHits}" Width="100"/>
                        <GridViewColumn Header="Stable (Hzσ)" DisplayMemberBinding="{Binding FrequencyStdDevHz}" Width="120"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Background="{StaticResource AppBorderBrush}"/>

        <!-- EQ Recommendations -->
        <GroupBox Grid.Row="3" Header="EQ Suggestions" Margin="0,10,0,10">
            <DockPanel>
                <TextBlock Text="Apply these cuts to your analog EQ to suppress feedback:" DockPanel.Dock="Top" Margin="5,0,0,5" FontSize="14" Foreground="Gray"/>
                <ListView x:Name="RecsList" BorderThickness="0" Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Band" DisplayMemberBinding="{Binding BandIndex}" Width="80"/>
                            <GridViewColumn Header="Freq (Hz)" DisplayMemberBinding="{Binding FrequencyHz}" Width="120"/>
                            <GridViewColumn Header="Cut (dB)" DisplayMemberBinding="{Binding GainDb}" Width="120"/>
                            <GridViewColumn Header="Q" DisplayMemberBinding="{Binding Q}" Width="80"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </GroupBox>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="{StaticResource AppPanelBrush}" Padding="5,2" CornerRadius="4">
            <DockPanel>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource AppForegroundBrush}" FontWeight="SemiBold"/>
                <TextBlock x:Name="VersionText" Text="v1.0" DockPanel.Dock="Right" HorizontalAlignment="Right" Foreground="Gray"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
