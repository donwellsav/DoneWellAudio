<Window x:Class="DoneWellAudio.Gui.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DoneWellAudio.Gui.Wpf"
        Title="DoneWellAudio - Feedback Detector" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Icons -->
        <Geometry x:Key="IconPlay">M8,5.14V19.14L19,12.14L8,5.14Z</Geometry>
        <Geometry x:Key="IconStop">M6,6H18V18H6V6Z</Geometry>
        <Geometry x:Key="IconPause">M14,19H18V5H14M6,19H10V5H6V19Z</Geometry>
        <Geometry x:Key="IconRefresh">M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z</Geometry>
        <Geometry x:Key="IconSettings">M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.95C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z</Geometry>

        <Geometry x:Key="IconCamera">M4,4H7L9,2H15L17,4H20A2,2 0 0,1 22,6V18A2,2 0 0,1 20,20H4A2,2 0 0,1 2,18V6A2,2 0 0,1 4,4M12,7A5,5 0 0,0 7,12A5,5 0 0,0 12,17A5,5 0 0,0 17,12A5,5 0 0,0 12,7M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z</Geometry>

        <Geometry x:Key="IconInfinity">M18,6C15.24,6 12.89,7.56 11.5,9.5C10.11,7.56 7.76,6 5,6A5,5 0 0,0 0,11A5,5 0 0,0 5,16C7.76,16 10.11,14.44 11.5,12.5C12.89,14.44 15.24,16 18,16A5,5 0 0,0 23,11A5,5 0 0,0 18,6M5,14A3,3 0 0,1 2,11A3,3 0 0,1 5,8C6.67,8 8.16,8.87 9.07,10.27C8.16,11.66 6.67,12.5 5,14M18,14C16.33,14 14.84,13.13 13.93,11.73C14.84,10.34 16.33,9.5 18,9.5A1.5,1.5 0 0,1 19.5,11A1.5,1.5 0 0,1 18,12.5V14Z</Geometry>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="IconToggleButton" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>
    </Window.Resources>

    <!-- Viewbox removed for responsive layout -->
        <DockPanel>
            <Menu DockPanel.Dock="Top" Background="{StaticResource AppPanelBrush}" Padding="5">
            <MenuItem Header="_File" Foreground="{StaticResource AppForegroundBrush}">
                <MenuItem Header="E_xit" Click="Exit_Click" Background="{StaticResource AppPanelBrush}" Foreground="{StaticResource AppForegroundBrush}"/>
            </MenuItem>
            <MenuItem Header="_Edit" Foreground="{StaticResource AppForegroundBrush}">
                <MenuItem Header="Cu_t" Command="Cut" Background="{StaticResource AppPanelBrush}" Foreground="{StaticResource AppForegroundBrush}"/>
                <MenuItem Header="_Copy" Command="Copy" Background="{StaticResource AppPanelBrush}" Foreground="{StaticResource AppForegroundBrush}"/>
                <MenuItem Header="_Paste" Command="Paste" Background="{StaticResource AppPanelBrush}" Foreground="{StaticResource AppForegroundBrush}"/>
            </MenuItem>
            <MenuItem Header="_Tools" Foreground="{StaticResource AppForegroundBrush}">
                <MenuItem Header="_Settings" Click="Settings_Click" Background="{StaticResource AppPanelBrush}" Foreground="{StaticResource AppForegroundBrush}"/>
            </MenuItem>
            <MenuItem Header="_Help" Foreground="{StaticResource AppForegroundBrush}">
                <MenuItem Header="_About" Click="About_Click" Background="{StaticResource AppPanelBrush}" Foreground="{StaticResource AppForegroundBrush}"/>
            </MenuItem>
        </Menu>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Controls -->
                <RowDefinition Height="*"/>    <!-- Main Content (Side by Side) -->
                <RowDefinition Height="Auto"/> <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- Top Control Bar -->
            <Border Grid.Row="0" Padding="10" CornerRadius="8" Background="{StaticResource AppPanelBrush}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>    <!-- Inputs (Expanded) -->
                        <ColumnDefinition Width="2*"/> <!-- Buttons (Fill evenly) -->
                        <ColumnDefinition Width="Auto"/> <!-- Settings -->
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Vertical" Grid.Column="0">
                        <DockPanel Margin="0,0,0,10" LastChildFill="True">
                            <TextBlock Text="Input:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                            <ComboBox x:Name="DeviceCombo" AutomationProperties.Name="Input device"/>
                        </DockPanel>

                        <DockPanel LastChildFill="True">
                             <TextBlock Text="Level:" VerticalAlignment="Center" Margin="0,0,10,0" Width="40" DockPanel.Dock="Left"/>
                             <ProgressBar x:Name="InputLevelMeter" Height="8" Maximum="1.0" Value="0.0" Foreground="{StaticResource AppAccentHighlightBrush}" Background="{StaticResource AppBorderBrush}" BorderThickness="0" AutomationProperties.Name="Input Level"/>
                        </DockPanel>

                    </StackPanel>

                    <UniformGrid Grid.Column="1" Rows="1" Margin="10,0">
                        <ToggleButton x:Name="ContinuousToggle" Style="{StaticResource IconToggleButton}" Click="ContinuousToggle_Click" ToolTip="Continuous Mode (Don't stop on feedback)">
                            <Viewbox Margin="5">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconInfinity}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Width="16" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock Text="LOOP"/>
                                </StackPanel>
                            </Viewbox>
                        </ToggleButton>
                        <Button x:Name="StartButton" Style="{StaticResource IconButton}" Click="Start_Click" ToolTip="Start Scanning (Space)">
                            <Viewbox Margin="5">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconPlay}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock Text="START"/>
                                </StackPanel>
                            </Viewbox>
                        </Button>
                        <Button x:Name="FreezeButton" Style="{StaticResource IconButton}" Click="Freeze_Click" ToolTip="Freeze Analysis (F)">
                            <Viewbox Margin="5">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconPause}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock Text="FREEZE"/>
                                </StackPanel>
                            </Viewbox>
                        </Button>
                        <Button x:Name="RescanButton" Style="{StaticResource IconButton}" Click="Rescan_Click" ToolTip="Reset &amp; Rescan (R)">
                             <Viewbox Margin="5">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconRefresh}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock Text="RESCAN"/>
                                </StackPanel>
                             </Viewbox>
                        </Button>
                        <Button x:Name="StopButton" Style="{StaticResource IconButton}" Click="Stop_Click" ToolTip="Stop Capture">
                            <Viewbox Margin="5">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconStop}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock Text="STOP"/>
                                </StackPanel>
                            </Viewbox>
                        </Button>
                        <Button x:Name="SnapshotButton" Style="{StaticResource IconButton}" Click="Snapshot_Click" ToolTip="Take Screenshot">
                            <Viewbox Margin="5">
                                <Path Data="{StaticResource IconCamera}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform"/>
                            </Viewbox>
                        </Button>
                    </UniformGrid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right">
                        <!-- RoomPanelToggle Removed -->
                        <Button x:Name="SettingsButton" Click="Settings_Click" Margin="0,0,0,0" Background="Transparent" BorderThickness="0" ToolTip="Settings" AutomationProperties.Name="Settings">
                            <Path Data="{StaticResource IconSettings}" Fill="{StaticResource AppForegroundBrush}" Width="20" Height="20" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content: Tabs -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <TabControl x:Name="MainTabs" Background="Transparent" BorderThickness="0">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TabControl.ItemContainerStyle>
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" BorderThickness="1,1,1,0" BorderBrush="{StaticResource AppBorderBrush}" Background="{StaticResource AppPanelBrush}" Margin="2,0">
                                            <ContentPresenter x:Name="ContentSite"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                ContentSource="Header"
                                                Margin="10,5"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AppBackgroundBrush}" />
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AppPanelBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </TabControl.Resources>

                    <!-- TAB 1: Live Analysis -->
                    <TabItem Header="Live Analysis">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>   <!-- Lists -->
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="300"/> <!-- Graph (Bottom) -->
                            </Grid.RowDefinitions>

                            <!-- Top: EQ & Candidates -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/> <!-- EQ Suggestions (Left) -->
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="*"/> <!-- Live Feedback (Right) -->
                                </Grid.ColumnDefinitions>

                                <!-- Left: EQ Suggestions -->
                                <GroupBox Grid.Column="0" Header="EQ Suggestions">
                                    <DockPanel>
                                        <TextBlock Text="Apply to EQ:" DockPanel.Dock="Top" Margin="5,0,0,5" FontSize="14" Foreground="{StaticResource AppForegroundBrush}"/>
                                        <ListView x:Name="RecsList" BorderThickness="0" AutomationProperties.Name="EQ Recommendations">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Foreground" Value="{Binding RowColor}"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Padding" Value="5"/>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Band" DisplayMemberBinding="{Binding BandIndex}" Width="60"/>
                                                    <GridViewColumn Header="Freq (Hz)" DisplayMemberBinding="{Binding FrequencyHz}" Width="100"/>
                                                    <GridViewColumn Header="Cut (dB)" DisplayMemberBinding="{Binding GainDb}" Width="100"/>
                                                    <GridViewColumn Header="Q" DisplayMemberBinding="{Binding Q}" Width="60"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </DockPanel>
                                </GroupBox>

                                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>

                                <!-- Right: Live Feedback Candidates -->
                                <GroupBox Grid.Column="2" Header="Live Feedback Candidates">
                                    <ListView x:Name="CandidatesList" BorderThickness="0" AutomationProperties.Name="Candidates List">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Foreground" Value="{Binding RowColor}"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="5"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Freq (Hz)" DisplayMemberBinding="{Binding FrequencyHz}" Width="100"/>
                                                <GridViewColumn Header="Conf" DisplayMemberBinding="{Binding Confidence}" Width="80"/>
                                                <GridViewColumn Header="Q~" DisplayMemberBinding="{Binding EstimatedQ}" Width="80"/>
                                                <GridViewColumn Header="Prom (dB)" DisplayMemberBinding="{Binding ProminenceDb}" Width="100"/>
                                                <GridViewColumn Header="Hits" DisplayMemberBinding="{Binding TotalHits}" Width="80"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </GroupBox>
                            </Grid>

                            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" ShowsPreview="True"/>

                            <!-- Bottom: Graph -->
                            <GroupBox Grid.Row="2">
                                <GroupBox.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Spectral Analysis" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ComboBox x:Name="GraphModeCombo" Width="120" SelectionChanged="GraphModeCombo_SelectionChanged" SelectedIndex="0">
                                            <ComboBoxItem Content="Spectrum" Tag="Spectrum"/>
                                            <ComboBoxItem Content="Waterfall" Tag="Waterfall"/>
                                            <ComboBoxItem Content="Confidence" Tag="Confidence"/>
                                        </ComboBox>
                                    </StackPanel>
                                </GroupBox.Header>
                                <Grid>
                                    <local:FeedbackGraphControl x:Name="FeedbackGraph" Mode="Spectrum"/>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </TabItem>

                    <!-- TAB 2: Room Analysis -->
                    <TabItem Header="Room Analysis">
                        <Grid x:Name="RoomPredictionPanel" Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <!-- Room Profile Name Removed -->

                                <!-- Metric Input Panel -->
                                <StackPanel x:Name="MetricInputPanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                                    <TextBox x:Name="RoomLengthInput" Width="60" Margin="0,0,5,0" VerticalContentAlignment="Center"/>
                                    <TextBlock Text="x" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="RoomWidthInput" Width="60" Margin="0,0,5,0" VerticalContentAlignment="Center"/>
                                    <TextBlock Text="x" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="RoomHeightInput" Width="60" Margin="0,0,5,0" VerticalContentAlignment="Center"/>
                                    <TextBlock Text="m" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                </StackPanel>

                                <!-- Imperial Input Panel (Grid Layout) -->
                                <StackPanel x:Name="ImperialInputPanel" Orientation="Vertical" VerticalAlignment="Center" Margin="0,-5,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/> <!-- Label Col -->
                                            <ColumnDefinition Width="Auto"/> <!-- Length Col -->
                                            <ColumnDefinition Width="Auto"/> <!-- Width Col -->
                                            <ColumnDefinition Width="Auto"/> <!-- Height Col -->
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/> <!-- Header -->
                                            <RowDefinition Height="Auto"/> <!-- Feet -->
                                            <RowDefinition Height="Auto"/> <!-- Inches -->
                                        </Grid.RowDefinitions>

                                        <!-- Headers -->
                                        <TextBlock Text="Length" Grid.Column="1" HorizontalAlignment="Center" Margin="0,0,5,2" FontSize="10" Foreground="Gray"/>
                                        <TextBlock Text="Width" Grid.Column="2" HorizontalAlignment="Center" Margin="0,0,5,2" FontSize="10" Foreground="Gray"/>
                                        <TextBlock Text="Height" Grid.Column="3" HorizontalAlignment="Center" Margin="0,0,5,2" FontSize="10" Foreground="Gray"/>

                                        <!-- Row 1: Feet -->
                                        <TextBlock Text="ft" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBox x:Name="RoomLengthFt" Grid.Row="1" Grid.Column="1" Width="50" Margin="0,0,5,2"/>
                                        <TextBox x:Name="RoomWidthFt" Grid.Row="1" Grid.Column="2" Width="50" Margin="0,0,5,2"/>
                                        <TextBox x:Name="RoomHeightFt" Grid.Row="1" Grid.Column="3" Width="50" Margin="0,0,5,2"/>

                                        <!-- Row 2: Inches -->
                                        <TextBlock Text="in" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBox x:Name="RoomLengthIn" Grid.Row="2" Grid.Column="1" Width="50" Margin="0,0,5,0"/>
                                        <TextBox x:Name="RoomWidthIn" Grid.Row="2" Grid.Column="2" Width="50" Margin="0,0,5,0"/>
                                        <TextBox x:Name="RoomHeightIn" Grid.Row="2" Grid.Column="3" Width="50" Margin="0,0,5,0"/>
                                    </Grid>
                                </StackPanel>

                                <Button x:Name="CalculateRoomButton" Content="Calculate" Click="CalculateRoomButton_Click" Padding="10,2" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Band Results (Left) -->
                                <GroupBox Header="Acoustic Predictions (per Band)" Grid.Column="0">
                                    <ListView x:Name="RoomBandsList" BorderThickness="0">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Foreground" Value="{Binding RowColor}"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="5"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Freq (Hz)" DisplayMemberBinding="{Binding FrequencyHz}" Width="80"/>
                                                <GridViewColumn Header="RT60 (s)" DisplayMemberBinding="{Binding Rt60Sabine, StringFormat=F2}" Width="80"/>
                                                <GridViewColumn Header="R" DisplayMemberBinding="{Binding RoomConstant, StringFormat=F1}" Width="60"/>
                                                <GridViewColumn Header="Dc (m)" DisplayMemberBinding="{Binding CriticalDistance, StringFormat=F2}" Width="60"/>
                                                <GridViewColumn Header="SG (dB)" DisplayMemberBinding="{Binding SystemGainInUse, StringFormat=F1}" Width="80"/>
                                                <GridViewColumn Header="Warnings" DisplayMemberBinding="{Binding WarningsString}" Width="200"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </GroupBox>

                                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>

                                <!-- Modes (Right) -->
                                <GroupBox Header="Room Modes (&lt; Schroeder)" Grid.Column="2">
                                    <ListView x:Name="RoomModesList" BorderThickness="0">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Foreground" Value="{Binding RowColor}"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="5"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Freq (Hz)" DisplayMemberBinding="{Binding FrequencyHz, StringFormat=F1}" Width="80"/>
                                                <GridViewColumn Header="Weight" DisplayMemberBinding="{Binding CouplingWeight, StringFormat=F2}" Width="60"/>
                                                <GridViewColumn Header="Type" DisplayMemberBinding="{Binding TypeString}" Width="80"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </GroupBox>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2" Background="{StaticResource AppPanelBrush}" Padding="5,2" CornerRadius="4">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource AppForegroundBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="Live Analysis" Click="LiveAnalysis_Click" Padding="10,2" Margin="0,0,5,0"/>
                        <Button Content="Room Analysis" Click="RoomAnalysis_Click" Padding="10,2"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="DONEWELL AUDIO" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AppAccentBrush}" Opacity="0.8" Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FFFF5500" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="VersionText" Text="v1.0" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

        </Grid>
        </DockPanel>
</Window>
