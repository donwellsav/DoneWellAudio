<Window x:Class="DoneWellAudio.Gui.Wpf.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message"
        Height="150" Width="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource AppBackgroundBrush}">
    <Border BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="MessageText"
                       Grid.Row="0"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Foreground="{StaticResource AppForegroundBrush}"
                       Margin="20"/>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,10">
                <Button x:Name="OkButton"
                        Content="OK"
                        Width="80"
                        Click="OkButton_Click"
                        Background="{StaticResource AppPanelBrush}"
                        Foreground="{StaticResource AppForegroundBrush}"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
