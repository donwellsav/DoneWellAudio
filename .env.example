# Sentry Error Reporting
# Get your DSN from: https://sentry.io → Settings → Projects → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Optional: Auth token for source map uploads (improves stack traces)
# Generate at: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=

# Required for source map uploads (used with SENTRY_AUTH_TOKEN)
SENTRY_BUILD_ENABLED=
SENTRY_ORG=
SENTRY_PROJECT=

# ML Data Pipeline — Supabase
# Supabase Edge Function URL for spectral snapshot ingestion
# Format: https://<PROJECT_ID>.supabase.co/functions/v1/ingest
SUPABASE_INGEST_URL=

# Optional dedicated shared secret between the Next.js ingest route and the
# Supabase Edge Function. Recommended over forwarding the service role key.
SUPABASE_INGEST_SHARED_SECRET=

# Supabase service role key (NOT the anon key — needed for RLS bypass)
# Get from: https://supabase.com → Project → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=
